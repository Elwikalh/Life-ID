generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  patient
  doctor
  clinic
  pharmacy
  lab
  radiology
  hospital
  pharma_company
  medical_rep
  emergency
  super_admin
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  cancelled
}

enum RxStatus {
  draft
  routed
  accepted
  unavailable
  confirmed
  delivered
  cancelled
}

enum DeliveryMethod {
  pickup
  home
}

model User {
  id              String  @id @default(cuid())
  role            Role
  fullName        String
  email           String? @unique
  phone           String? @unique
  specialty       String?
  bio             String?
  consultationFee Int?
nationalId       String?  @unique
idPhotoFrontUrl  String?
idPhotoBackUrl   String?
idVerified       Boolean  @default(false)

  branchesCount  Int?
  city           String?
  clinicLocation String?
  workingDays    String[] @default([])
  workFrom       String?
  workTo         String?
  homeService    Boolean  @default(false)
  paymentPolicy  String?

  medicalId      MedicalId?
  appointments   Appointment[]   @relation("PatientAppointments")
  provided       Appointment[]   @relation("ProviderAppointments")
  partnerships   Partnership[]
  invitations    Invitation[]
  photo          UserPhoto?
  pharmaProducts PharmaProduct[]
  medicalReps    MedicalRep[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model MedicalId {
  id                String   @id @default(cuid())
  user              User     @relation(fields: [userId], references: [id])
  userId            String   @unique
  qrCode            String   @unique
  bloodType         String?
  allergies         String[]
  chronicConditions String[]
  medications       String[]
  emergencyName     String?
  emergencyPhone    String?
}

model Appointment {
  id           String            @id @default(cuid())
  patient      User              @relation("PatientAppointments", fields: [patientId], references: [id])
  patientId    String
  provider     User              @relation("ProviderAppointments", fields: [providerId], references: [id])
  providerId   String
  scheduledAt  DateTime
  status       AppointmentStatus @default(pending)
  priceEGP     Int               @default(0)
  discountPct  Int               @default(0)
  prescription Prescription?
  createdAt    DateTime          @default(now())
}

model Prescription {
  id                String          @id @default(cuid())
  appointment       Appointment     @relation(fields: [appointmentId], references: [id])
  appointmentId     String          @unique
  doctorId          String
  patientId         String?
  items             Json
diagnosis         String?
clinicalNotes     String?
labRequests       Json?
imagingRequests   Json?
dangerNote        String?
emergencyPlan     String?
followUpAt        DateTime?
followUpNote      String?
  status            RxStatus        @default(draft)
  currentPharmacyId String?
  triedPharmacyIds  String[]        @default([])
  deliveryMethod    DeliveryMethod?
  patientAddress    String?
  patientPhone      String?
  routingNote       String?
  createdAt         DateTime        @default(now())

  @@index([doctorId])
  @@index([patientId])
  @@index([currentPharmacyId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Partnership {
  id           String   @id @default(cuid())
  owner        User     @relation(fields: [ownerId], references: [id])
  ownerId      String
  partnerName  String
  partnerType  String
  partnerPhone String?
  discountPct  Int      @default(0)
  patientPct   Int      @default(0)
  doctorPct    Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())

  @@index([ownerId])
}

model Invitation {
  id            String   @id @default(cuid())
  inviter       User     @relation(fields: [inviterId], references: [id])
  inviterId     String
  inviteeName   String
  inviteeType   String
  contact       String?
  requestedPct  Int?
  message       String?
  status        String   @default("pending")
  inviteeUserId String?
  currentPct    Int?
  lastActor     String?
  createdAt     DateTime @default(now())

  @@index([inviterId])
  @@index([inviteeUserId])
}

model UserPhoto {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  url       String
  updatedAt DateTime @updatedAt
}

model PharmaProduct {
  id         String   @id @default(cuid())
  company    User     @relation(fields: [companyId], references: [id])
  companyId  String
  name       String
  category   String?
  dosageForm String?
  price      Int?
  note       String?
  createdAt  DateTime @default(now())

  @@index([companyId])
}

model MedicalRep {
  id           String     @id @default(cuid())
  company      User       @relation(fields: [companyId], references: [id])
  companyId    String
  name         String
  phone        String?
  region       String?
  note         String?
  linkCode     String?    @unique
  linkedUserId String?    @unique
  visits       RepVisit[]
  createdAt    DateTime   @default(now())

  @@index([companyId])
}

model RepVisit {
  id         String     @id @default(cuid())
  rep        MedicalRep @relation(fields: [repId], references: [id], onDelete: Cascade)
  repId      String
  doctorName String
  specialty  String?
  region     String?
  outcome    String?
  note       String?
  visitDate  DateTime   @default(now())
  createdAt  DateTime   @default(now())

  @@index([repId])
}

model PharmacyLink {
  id           String   @id @default(cuid())
  doctorId     String
  pharmacyId   String
  pharmacyName String
  priority     Int      @default(1)
  createdAt    DateTime @default(now())

  @@unique([doctorId, pharmacyId])
  @@index([doctorId])
}
model Review {
  id          String   @id @default(cuid())
  providerId  String
  patientId   String
  patientName String?
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([providerId, patientId])
  @@index([providerId])
}
model Branch {
  id         String            @id @default(cuid())
  providerId String
  provider   User              @relation("ProviderBranches", fields: [providerId], references: [id], onDelete: Cascade)
  name       String
  city       String?
  address    String?
  phone      String?
  isMain     Boolean           @default(false)
  createdAt  DateTime          @default(now())
  staff      StaffMembership[]

  @@index([providerId])
}

model StaffMembership {
  id          String   @id @default(cuid())
  providerId  String
  provider    User     @relation("ProviderStaff", fields: [providerId], references: [id], onDelete: Cascade)
  memberId    String
  member      User     @relation("StaffMemberships", fields: [memberId], references: [id], onDelete: Cascade)
  jobTitle    String?
  permissions String[]
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  status      String   @default("active")
  createdAt   DateTime @default(now())

  @@unique([providerId, memberId])
  @@index([providerId])
  @@index([memberId])
}
